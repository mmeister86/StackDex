{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": false,
    "types": ["node", "vitest/globals"]
  },
  "include": ["convex/**/*.ts", "vitest.config.ts"]
}
